# ─────────────────────────────────────────────────────────────────────────
# mcp-gsuite — environment template.
# Copy to `.env.local` (loaded in every mode) or `.env.development` (for
# `bun run server:mcp:dev`), or set these in your MCP client's `env` block.
# See README.md for full setup. `.env.*` files are gitignored; only
# `.env*.example` templates are committed.
# ─────────────────────────────────────────────────────────────────────────

# Google Cloud OAuth Client Credentials
# Get these from Google Cloud Console > APIs & Services > Credentials.
# Create an "OAuth 2.0 Client ID" of type "Web application" with the
# redirect URI listed below in MCP_GSUITE_REDIRECT_URI.

# OAuth 2.0 Client ID (looks like "xxxxx.apps.googleusercontent.com")
MCP_GSUITE_CLIENT_ID=your-client-id-here

# OAuth 2.0 Client Secret
MCP_GSUITE_CLIENT_SECRET=your-client-secret-here

# --- Optional overrides (defaults shown) ---------------------------------

# OAuth redirect URI. Must match what is registered in Google Cloud.
# MCP_GSUITE_REDIRECT_URI=http://localhost:3334/auth/callback

# Port the auth server listens on (must match the redirect URI port).
# MCP_GSUITE_AUTH_PORT=3334

# Space-separated OAuth scopes requested for the access token.
# MCP_GSUITE_SCOPES=https://www.googleapis.com/auth/gmail.modify https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/drive.readonly https://www.googleapis.com/auth/spreadsheets

# Token file location. Defaults to ~/.mcp-gsuite-tokens.json. Override for
# multi-account setups (e.g. personal vs work).
# MCP_GSUITE_TOKEN_PATH=~/.mcp-gsuite-tokens.json

# Directory where attachment downloads are written. Defaults to ~/Downloads.
# Any caller-provided outputPath is resolved relative to this root and
# rejected if it escapes (lexically or via symlink).
# MCP_GSUITE_DOWNLOAD_PATH=~/Downloads

# Maximum size (in decoded bytes) for inline attachment_get responses (no
# outputPath). Above this, callers must use outputPath to write to disk.
# Default: 262144 (256 KiB).
# MCP_GSUITE_INLINE_ATTACHMENT_MAX_BYTES=262144

# ─────────────────────────────────────────────────────────────────────────
# Access level & audit log — conventions shared across all HNR MCP servers.
# ─────────────────────────────────────────────────────────────────────────

# Maximum access level to register at server boot. One of: read, write,
# destructive. Levels nest: `read` registers only read-only tools; `write`
# adds non-destructive mutations; `destructive` adds delete/overwrite tools.
# A tool's level is derived from its MCP annotations (readOnlyHint /
# destructiveHint), not its name — see src/utils/access-level.ts.
# Default: read.
# MCP_GSUITE_ACCESS_LEVEL=destructive

# Audit log of tool invocations, written as JSONL. One of: off, writes, all.
#   off    — no audit logging
#   writes — record write/destructive calls only (default)
#   all    — record every call, including reads
# MCP_GSUITE_AUDIT_LOG=writes

# Path to the audit log file.
# MCP_GSUITE_AUDIT_LOG_PATH=~/.local/state/mcp-gsuite/audit.jsonl

# Rotate the audit log when it exceeds this many bytes (0 disables rotation).
# Default: 10485760 (10 MiB).
# MCP_GSUITE_AUDIT_LOG_MAX_BYTES=10485760

# Number of rotated audit logs to keep. Default: 5.
# MCP_GSUITE_AUDIT_LOG_KEEP=5
